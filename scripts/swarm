#!/bin/bash
# swarm — Peer-mesh multi-agent coordination over tmux
#
# Enables Claude Code sessions to dispatch tasks to, monitor, and collect
# results from other CC sessions running in tmux windows.
#
# Usage:
#   swarm list                              # List all CC sessions
#   swarm dispatch <target> <prompt>        # Send prompt to a CC session
#   swarm dispatch <target> --file <path>   # Send file reference (agent reads the file)
#   swarm monitor <target>                  # Capture pane output
#   swarm monitor <target> --wait [timeout] # Wait until session is idle
#   swarm monitor <target> --tail <n>       # Last n lines
#   swarm collect <target>                  # Get last assistant response
#   swarm status                            # Dashboard of all agents

set -euo pipefail

SWARM_DIR="${SWARM_DIR:-$HOME/.claude-swarm}"
AGENTS_DIR="$SWARM_DIR/agents"
DISPATCH_DIR="$SWARM_DIR/dispatches"
MAILBOX_DIR="$SWARM_DIR/mailbox"
TASKS_DIR="$SWARM_DIR/tasks"
QA_DIR="$SWARM_DIR/qa"
TOPOLOGY_FILE="$SWARM_DIR/topology.json"
ACTIVITY_LOG="$SWARM_DIR/activity.jsonl"
if command -v brew >/dev/null 2>&1; then
    TMUX_BIN="$(brew --prefix)/bin/tmux"
else
    TMUX_BIN="tmux"
fi

mkdir -p "$AGENTS_DIR" "$DISPATCH_DIR" "$MAILBOX_DIR" "$TASKS_DIR"

# Source lock library
SCRIPT_SRC="$0"
while [ -L "$SCRIPT_SRC" ]; do SCRIPT_SRC="$(readlink "$SCRIPT_SRC")"; done
SCRIPT_BASE="$(cd "$(dirname "$SCRIPT_SRC")" && pwd -P)"
if [ -f "$SCRIPT_BASE/swarm_lock.sh" ]; then
    # shellcheck source=scripts/swarm_lock.sh
    source "$SCRIPT_BASE/swarm_lock.sh"
fi

# Log an activity event to the unified JSONL log
# Usage: log_activity <action> [key=value ...]
log_activity() {
    local action="$1"
    shift
    local ts
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    # Build all --arg pairs in one jq call (no per-field subprocess)
    local -a jq_args=(--arg action "$action" --arg ts "$ts")
    local jq_filter='{action: $action, timestamp: $ts'
    local idx=0
    while [ $# -gt 0 ]; do
        local kvar="k${idx}" vvar="v${idx}"
        jq_args+=(--arg "$kvar" "${1%%=*}" --arg "$vvar" "${1#*=}")
        jq_filter+=", (\$$kvar): \$$vvar"
        idx=$((idx + 1))
        shift
    done
    jq_filter+='}'
    jq -c -n "${jq_args[@]}" "$jq_filter" >> "$ACTIVITY_LOG"
}

# Validate that a value is a positive integer
require_int() {
    local name="$1" val="$2"
    if ! [[ "$val" =~ ^[0-9]+$ ]]; then
        echo "Error: $name must be a positive integer, got '$val'" >&2
        exit 1
    fi
}

# --- Utility functions ---

# Check if a pane is running Claude Code
is_cc_pane() {
    local target="$1"
    local title
    title=$($TMUX_BIN display-message -t "$target" -p '#{pane_title}' 2>/dev/null || echo "")
    # CC sets pane_title with status prefix: ✳ (idle) or braille spinner (busy)
    [[ "$title" == "✳"* || "$title" == "⠂"* || "$title" == "⠐"* ]] && return 0
    # Fallback: CC startup before session name loads
    [[ "$title" == *"Claude Code"* ]] && return 0
    return 1
}

# Get idle/busy status of a CC pane from pane_title
# CC sets pane_title with a status prefix character:
#   ✳ = idle (waiting for input)
#   ⠂/⠐ = busy (processing, spinner animation)
get_status() {
    local target="$1"
    local title
    title=$($TMUX_BIN display-message -t "$target" -p '#{pane_title}' 2>/dev/null || echo "")
    case "$title" in
        "✳"*) echo "idle" ;;
        "⠂"*|"⠐"*) echo "busy" ;;
        *"Claude Code"*) echo "idle" ;;
        *) echo "exited" ;;
    esac
}

# Get session ID for a pane from agent registry or filesystem
get_session_id() {
    local target="$1"
    local safe_name
    safe_name=$(echo "$target" | tr ':.' '_')

    # Check agent registry first
    if [ -f "$AGENTS_DIR/${safe_name}.json" ]; then
        jq -r '.session_id' "$AGENTS_DIR/${safe_name}.json"
        return
    fi

    # Fallback: find most recent session JSONL matching the pane's CWD
    local cwd
    cwd=$(get_cwd "$target")
    if [ -z "$cwd" ]; then
        echo ""
        return
    fi

    # Resolve symlinks
    if [ -d "$cwd" ]; then
        cwd=$(cd "$cwd" && pwd -P)
    fi

    local encoded_path
    encoded_path=$(echo "$cwd" | sed 's|/|-|g')
    local project_dir="$HOME/.claude/projects/${encoded_path}"

    if [ -d "$project_dir" ]; then
        # Only use filesystem fallback if there are few JSONL files (unique CWD)
        local jsonl_count
        jsonl_count=$(ls "$project_dir"/*.jsonl 2>/dev/null | wc -l)
        if [ "$jsonl_count" -le 3 ]; then
            local latest
            latest=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -1)
            if [ -n "$latest" ]; then
                basename "$latest" .jsonl
                return
            fi
        fi
    fi

    echo ""
}

# Get CWD for a pane from agent registry
get_cwd() {
    local target="$1"
    local safe_name
    safe_name=$(echo "$target" | tr ':.' '_')

    if [ -f "$AGENTS_DIR/${safe_name}.json" ]; then
        jq -r '.cwd' "$AGENTS_DIR/${safe_name}.json"
        return
    fi

    # Fallback: tmux pane CWD
    $TMUX_BIN display-message -t "$target" -p '#{pane_current_path}' 2>/dev/null || echo ""
}

# Wait for CC to be fully ready in a pane
# Detection: CC process alive + hook reports idle (or no tools running)
wait_cc_ready() {
    local target="$1"
    local timeout="${2:-180}"
    local elapsed=0

    while [ $elapsed -lt $timeout ]; do
        if is_cc_pane "$target"; then
            local status
            status=$(get_status "$target")
            if [ "$status" = "idle" ]; then
                return 0
            fi
        fi
        sleep 3
        elapsed=$((elapsed + 3))
        printf "\r  [%3ds] waiting for CC ready in %s..." "$elapsed" "$target"
    done
    echo ""
    return 1
}

# --- Commands ---

cmd_list() {
    local verbose=false
    while [ $# -gt 0 ]; do
        case "$1" in
            -v|--verbose) verbose=true; shift ;;
            *) shift ;;
        esac
    done

    if $verbose; then
        printf "%-15s %-8s %-30s %-40s %s\n" "PANE" "STATUS" "NAME" "SESSION_ID" "CWD"
        printf "%-15s %-8s %-30s %-40s %s\n" "----" "------" "----" "----------" "---"
    else
        printf "%-15s %-8s %-30s %s\n" "PANE" "STATUS" "NAME" "CWD"
        printf "%-15s %-8s %-30s %s\n" "----" "------" "----" "---"
    fi

    # Scan all tmux panes
    while IFS=$'\t' read -r sess_name win_idx pane_idx pane_cmd pane_title pane_path; do
        local target="${sess_name}:${win_idx}.${pane_idx}"

        # Check if this pane is a registered CC session (agent card exists from hook)
        local safe_name
        safe_name=$(echo "$target" | tr ':.' '_')
        if [ ! -f "$SWARM_DIR/agents/${safe_name}.json" ]; then
            continue
        fi

        local status
        status=$(get_status "$target")
        local sid
        sid=$(get_session_id "$target")
        local cwd="$pane_path"

        # Extract session name from pane title (strip leading status icons like ⠐ ✳)
        local name
        name=$(echo "$pane_title" | sed 's/^[^a-zA-Z[]*//; s/^[[:space:]]*//' | cut -c1-28)
        [ -z "$name" ] && name="(unnamed)"

        # Shorten CWD
        local display_cwd="${cwd/#$HOME/~}"

        if $verbose; then
            local short_sid="${sid:0:36}"
            [ -z "$short_sid" ] && short_sid="(unregistered)"
            printf "%-15s %-8s %-30s %-40s %s\n" "$target" "$status" "$name" "$short_sid" "$display_cwd"
        else
            printf "%-15s %-8s %-30s %s\n" "$target" "$status" "$name" "$display_cwd"
        fi
    done < <($TMUX_BIN list-panes -a -F "#{session_name}	#{window_name}	#{pane_index}	#{pane_current_command}	#{pane_title}	#{pane_current_path}" 2>/dev/null)
}

cmd_dispatch() {
    local target=""
    local task_id=""
    local prompt=""
    local prompt_file=""
    local force=false

    # Parse args: either --task <id> or <target> <prompt|--file path>
    while [ $# -gt 0 ]; do
        case "$1" in
            --task)
                task_id="$2"
                shift 2
                ;;
            --file)
                prompt_file="$2"
                shift 2
                ;;
            --force)
                force=true
                shift
                ;;
            *)
                if [ -z "$target" ]; then
                    target="$1"
                    shift
                elif [ -z "$prompt" ]; then
                    prompt="$*"
                    break
                else
                    shift
                fi
                ;;
        esac
    done

    # --- If no --task, auto-create task from target + prompt ---
    if [ -z "$task_id" ]; then
        if [ -z "$target" ]; then
            echo "Usage: swarm dispatch <target> <prompt|--file path|--task task_id>" >&2
            exit 1
        fi

        # Resolve prompt content
        local prompt_content=""
        if [ -n "$prompt_file" ]; then
            if [ ! -f "$prompt_file" ]; then
                echo "Error: File not found: $prompt_file" >&2
                exit 1
            fi
            prompt_content=$(cat "$prompt_file")
        elif [ -n "$prompt" ]; then
            prompt_content="$prompt"
        else
            echo "Error: No prompt provided" >&2
            exit 1
        fi

        # Auto-generate task_id and detect caller pane
        task_id="auto_$(date +%Y%m%d_%H%M%S)_$$"
        local from_pane=""
        if [ -n "${TMUX:-}" ]; then
            from_pane=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "")
        fi
        : "${from_pane:=unknown}"

        # Create task structure
        local task_dir="$TASKS_DIR/$task_id"
        mkdir -p "$task_dir"

        local created_at
        created_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

        jq -n \
            --arg task_id "$task_id" \
            --arg from "$from_pane" \
            --arg to "$target" \
            --arg type "task" \
            --arg created "$created_at" \
            --arg result_path "$task_dir/result.md" \
            '{task_id: $task_id, from: $from, to: $to, type: $type, created_at: $created,
              result_path: $result_path}' \
            > "$task_dir/envelope.json"

        echo "$prompt_content" > "$task_dir/prompt.md"

        jq -n --arg ts "$created_at" \
            '{state: "created", created_at: $ts, transitions: [{from: "none", to: "created", at: $ts}]}' \
            > "$task_dir/status.json"
    fi

    # --- Dispatch the task ---
    local task_dir="$TASKS_DIR/$task_id"

    # Validate task directory structure
    if [ ! -d "$task_dir" ]; then
        echo "Error: task directory not found: $task_dir" >&2
        exit 1
    fi
    for required_file in envelope.json prompt.md status.json; do
        if [ ! -f "$task_dir/$required_file" ]; then
            echo "Error: $required_file missing in $task_dir" >&2
            exit 1
        fi
    done

    # Read envelope
    local env_task_id env_from env_to
    env_task_id=$(jq -r '.task_id // empty' "$task_dir/envelope.json")
    env_from=$(jq -r '.from // empty' "$task_dir/envelope.json")
    env_to=$(jq -r '.to // empty' "$task_dir/envelope.json")

    if [ -z "$env_task_id" ] || [ -z "$env_from" ] || [ -z "$env_to" ]; then
        echo "Error: envelope.json missing required fields (task_id, from, to)" >&2
        exit 1
    fi

    target="$env_to"

    # Dedup check + status update (atomic, under lock to prevent TOCTOU race)
    local lock_dir="$SWARM_DIR/locks/dispatch_${task_id}"
    local current_state timestamp

    _dispatch_dedup_and_transition() {
        current_state=$(jq -r '.state' "$task_dir/status.json")
        if [ "$current_state" = "dispatched" ] && ! $force; then
            echo "Error: task '$task_id' already dispatched. Use --force to re-dispatch." >&2
            return 1
        fi
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        jq --arg ts "$timestamp" --arg prev "$current_state" '
            .state = "dispatched" |
            .dispatched_at = $ts |
            .transitions += [{from: $prev, to: "dispatched", at: $ts}]
        ' "$task_dir/status.json" > "$task_dir/status.json.tmp" \
            && mv "$task_dir/status.json.tmp" "$task_dir/status.json"
    }

    mkdir -p "$SWARM_DIR/locks"
    if ! with_lock "$lock_dir" _dispatch_dedup_and_transition; then
        exit 1
    fi

    # Update target agent's card
    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')
    local card_file="$AGENTS_DIR/${safe_target}.json"
    if [ -f "$card_file" ]; then
        jq --arg tid "$task_id" '.current_task = $tid' "$card_file" > "$card_file.tmp" \
            && mv "$card_file.tmp" "$card_file"
    fi

    # Append notification instruction to prompt.md
    # On --force re-dispatch, use current dispatcher's pane (not original envelope's from)
    local notify_target="$env_from"
    if $force && [ -n "${TMUX:-}" ]; then
        local current_pane
        current_pane=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "")
        [ -n "$current_pane" ] && notify_target="$current_pane"
    fi

    # Remove old notification footer before appending updated one
    if $force && grep -q "swarm send.*done: $task_id" "$task_dir/prompt.md" 2>/dev/null; then
        sed -i '' '/^---$/,/^```$/{ /swarm send.*done: '"$task_id"'/{ N; d; }; }' "$task_dir/prompt.md" 2>/dev/null || true
    fi

    if ! grep -q "swarm send.*done: $task_id" "$task_dir/prompt.md" 2>/dev/null; then
        cat >> "$task_dir/prompt.md" <<NOTIFY

---
**When you finish this task**, notify the dispatcher:
\`\`\`bash
swarm send $notify_target "done: $task_id"
\`\`\`
NOTIFY
    fi

    # Dispatch via tmux
    if [ -z "${TMUX:-}" ] && ! $TMUX_BIN has-session -t "${target%%:*}" 2>/dev/null; then
        log_activity "dispatch" "task_id=$task_id" "target=$target"
        echo "Dispatch prepared: task=$task_id target=$target (tmux unavailable, skipping paste)"
        return 0
    fi

    if ! $TMUX_BIN has-session -t "${target%%:*}" 2>/dev/null; then
        echo "Error: tmux session '${target%%:*}' not found" >&2
        exit 1
    fi

    if ! is_cc_pane "$target"; then
        echo "Error: $target does not appear to be running Claude Code" >&2
        exit 1
    fi

    local status
    status=$(get_status "$target")
    if [ "$status" = "busy" ] && ! $force; then
        echo "Warning: $target appears busy (status: $status). Use --force to send anyway." >&2
        exit 1
    fi

    # Send "Read and execute" message
    local dispatch_msg="Read and execute the task in $task_dir/prompt.md"
    local buf_name="swarm_$$_$(date +%s)_$RANDOM"
    echo "$dispatch_msg" | $TMUX_BIN load-buffer -b "$buf_name" -
    $TMUX_BIN paste-buffer -b "$buf_name" -t "$target" -d
    sleep 0.3
    $TMUX_BIN send-keys -t "$target" Enter

    # Log dispatch event
    local log_file="$DISPATCH_DIR/$(date +%Y%m%d_%H%M%S)_${safe_target}.json"
    jq -n \
        --arg target "$target" \
        --arg task_id "$task_id" \
        --arg timestamp "$timestamp" \
        --arg status "$status" \
        '{target: $target, task_id: $task_id, timestamp: $timestamp,
          status_at_dispatch: $status}' \
        > "$log_file"

    log_activity "dispatch" "task_id=$task_id" "target=$target"
    echo "Dispatched: task=$task_id -> $target (was: $status)"
}

cmd_monitor() {
    local target="$1"
    shift

    local mode="capture"
    local lines=50
    local timeout=600

    while [ $# -gt 0 ]; do
        case "$1" in
            --wait)
                mode="wait"
                shift
                # Next arg is timeout only if numeric
                if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
                    timeout="$1"
                    shift
                fi
                ;;
            --tail)
                mode="tail"
                lines="${2:-30}"
                require_int "--tail" "$lines"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    case "$mode" in
        capture)
            $TMUX_BIN capture-pane -t "$target" -p -S "-$lines"
            ;;
        tail)
            $TMUX_BIN capture-pane -t "$target" -p -S "-$lines"
            ;;
        wait)
            local elapsed=0
            echo "Waiting for $target to become idle (timeout: ${timeout}s)..."
            # Grace period: wait for target to start processing first
            local grace=0
            while [ $grace -lt 10 ]; do
                local pre_status
                pre_status=$(get_status "$target")
                if [ "$pre_status" = "busy" ]; then
                    break
                fi
                sleep 1
                grace=$((grace + 1))
            done
            elapsed=$grace
            while true; do
                local status
                status=$(get_status "$target")
                if [ "$status" = "idle" ] && [ $elapsed -ge 5 ]; then
                    echo ""
                    echo "$target is idle (after ${elapsed}s)"
                    return 0
                fi

                sleep 5
                elapsed=$((elapsed + 5))
                if [ $elapsed -ge "$timeout" ]; then
                    echo ""
                    echo "Timeout: $target still not idle after ${timeout}s" >&2
                    return 1
                fi

                # Progress indicator
                local last_line
                last_line=$($TMUX_BIN capture-pane -t "$target" -p 2>/dev/null | grep -v '^$' | tail -1)
                printf "\r[%4ds] %-80s" "$elapsed" "${last_line:0:80}"
            done
            ;;
    esac
}

cmd_collect() {
    local target="$1"

    local sid
    sid=$(get_session_id "$target")
    if [ -z "$sid" ]; then
        echo "Error: No session ID known for $target. Session may not be registered." >&2
        echo "Falling back to pane capture..." >&2
        $TMUX_BIN capture-pane -t "$target" -p | tail -30
        return 1
    fi

    # Try pre-resolved JSONL path from registry first
    local safe_name log_file=""
    safe_name=$(echo "$target" | tr ':.' '_')
    if [ -f "$AGENTS_DIR/${safe_name}.json" ]; then
        log_file=$(jq -r '.jsonl_path // empty' "$AGENTS_DIR/${safe_name}.json" 2>/dev/null)
    fi

    # Fallback: compute path from CWD + session ID
    if [ -z "$log_file" ] || [ ! -f "$log_file" ]; then
        local cwd
        cwd=$(get_cwd "$target")
        if [ -z "$cwd" ]; then
            echo "Error: No CWD known for $target" >&2
            return 1
        fi
        if [ -d "$cwd" ]; then
            cwd=$(cd "$cwd" && pwd -P)
        fi
        local encoded_path
        encoded_path=$(echo "$cwd" | sed 's|/|-|g')
        log_file="$HOME/.claude/projects/${encoded_path}/${sid}.jsonl"
    fi

    if [ ! -f "$log_file" ]; then
        echo "Error: Session log not found: $log_file" >&2
        echo "Falling back to pane capture..." >&2
        $TMUX_BIN capture-pane -t "$target" -p | tail -30
        return 1
    fi

    # Extract last assistant text response
    python3 -c "
import json, sys

log_file = '$log_file'
last_text = None

# Read backwards efficiently — read last 500KB
import os
fsize = os.path.getsize(log_file)
read_from = max(0, fsize - 512000)

with open(log_file, 'rb') as f:
    f.seek(read_from)
    if read_from > 0:
        f.readline()  # skip partial line
    for raw_line in f:
        try:
            obj = json.loads(raw_line)
        except (json.JSONDecodeError, ValueError):
            continue
        msg = obj.get('message', {})
        if msg.get('role') != 'assistant':
            continue
        content = msg.get('content', [])
        if isinstance(content, list):
            texts = [c['text'] for c in content if isinstance(c, dict) and c.get('type') == 'text']
            if texts:
                last_text = texts[-1]
        elif isinstance(content, str) and content:
            last_text = content

if last_text:
    print(last_text)
else:
    print('(no assistant response found)', file=sys.stderr)
    sys.exit(1)
"
}

cmd_status() {
    echo "=== Claude Swarm Status ==="
    echo ""

    local total=0
    local idle=0
    local busy=0

    printf "%-15s %-8s %-25s %s\n" "PANE" "STATUS" "LAST ACTIVITY" "CWD"
    printf "%-15s %-8s %-25s %s\n" "----" "------" "-------------" "---"

    while IFS=$'\t' read -r sess_name win_idx pane_idx pane_cmd pane_title pane_path; do
        local target="${sess_name}:${win_idx}.${pane_idx}"

        # Use same detection as cmd_list: agent card must exist
        local safe_name
        safe_name=$(echo "$target" | tr ':.' '_')
        if [ ! -f "$SWARM_DIR/agents/${safe_name}.json" ]; then
            continue
        fi

        total=$((total + 1))
        local status
        status=$(get_status "$target")
        [ "$status" = "idle" ] && idle=$((idle + 1))
        [ "$status" = "busy" ] && busy=$((busy + 1))

        # Get last non-empty line as activity indicator
        local last_line
        last_line=$($TMUX_BIN capture-pane -t "$target" -p 2>/dev/null | grep -v '^$' | grep -vE 'bypass|permissions|shift.tab' | tail -1 || echo "")
        last_line="${last_line:0:25}"

        local display_cwd="${pane_path/#$HOME/~}"

        printf "%-15s %-8s %-25s %s\n" "$target" "$status" "$last_line" "$display_cwd"
    done < <($TMUX_BIN list-panes -a -F "#{session_name}	#{window_name}	#{pane_index}	#{pane_current_command}	#{pane_title}	#{pane_current_path}" 2>/dev/null)

    echo ""
    echo "Total: $total | Idle: $idle | Busy: $busy | Unknown: $((total - idle - busy))"
}

cmd_register_all() {
    (  # Subshell: set +e scoped, auto-restores on exit
    set +e
    echo "Registering CC sessions by correlating tmux panes with session files..."
    local count=0

    while IFS=$'\t' read -r sess_name win_idx pane_idx pane_cmd pane_title pane_path; do
        local target="${sess_name}:${win_idx}.${pane_idx}"
        # CC detection: pane_title starts with ✳ (idle) or braille spinner (busy)
        if ! [[ "$pane_title" == "✳"* || "$pane_title" == "⠂"* || "$pane_title" == "⠐"* || "$pane_title" == *"Claude Code"* ]]; then
            continue
        fi

        local safe_name
        safe_name=$(echo "$target" | tr ':.' '_')
        if [ -f "$AGENTS_DIR/${safe_name}.json" ]; then
            echo "  $target — already registered"
            count=$((count + 1))
            continue
        fi

        # Try to find the session ID from the CC process
        # Get pane PID → find claude child → extract session from JSONL correlation
        local pane_pid
        pane_pid=$($TMUX_BIN display-message -t "$target" -p '#{pane_pid}' 2>/dev/null || echo "")
        local cc_pid=""
        if [ -n "$pane_pid" ]; then
            # Find claude child process
            cc_pid=$(pgrep -P "$pane_pid" 2>/dev/null | head -1)
        fi

        # Find session ID: check for --session-id in process args
        local session_id=""
        if [ -n "$cc_pid" ]; then
            local args
            args=$(ps -p "$cc_pid" -o args= 2>/dev/null || echo "")
            if [[ "$args" == *"--session-id"* ]]; then
                session_id=$(echo "$args" | sed 's/.*--session-id[= ]*//' | awk '{print $1}')
            fi

            # Fallback: find --resume in args
            if [ -z "$session_id" ] && [[ "$args" == *"--resume"* ]]; then
                session_id=$(echo "$args" | sed 's/.*--resume[= ]*//' | awk '{print $1}')
            fi
        fi

        # Fallback: use most recent active JSONL for this CWD
        if [ -z "$session_id" ]; then
            local cwd="$pane_path"
            if [ -d "$cwd" ]; then
                cwd=$(cd "$cwd" && pwd -P)
            fi
            local encoded_path
            encoded_path=$(echo "$cwd" | sed 's|/|-|g')
            local project_dir="$HOME/.claude/projects/${encoded_path}"

            if [ -d "$project_dir" ]; then
                # Find JSONL modified in last 24h, pick most recent
                local candidates
                candidates=$(find "$project_dir" -name "*.jsonl" -mmin -1440 -type f 2>/dev/null | sort -t/ -k1 | while read f; do
                    echo "$(stat -f '%m' "$f") $(basename "$f" .jsonl)"
                done | sort -rn | head -5)

                # If only one candidate, use it
                local num_candidates
                num_candidates=$(echo "$candidates" | grep -c . || echo 0)
                if [ "$num_candidates" -eq 1 ]; then
                    session_id=$(echo "$candidates" | awk '{print $2}')
                elif [ "$num_candidates" -le 5 ]; then
                    # Few candidates — pick most recent not already registered
                    while IFS=' ' read -r _ sid; do
                        local already_taken=false
                        for regfile in "$AGENTS_DIR"/*.json; do
                            [ -f "$regfile" ] || continue
                            if jq -r '.session_id' "$regfile" 2>/dev/null | grep -q "^${sid}$"; then
                                already_taken=true
                                break
                            fi
                        done
                        if [ "$already_taken" = "false" ]; then
                            session_id="$sid"
                            break
                        fi
                    done <<< "$candidates"
                fi
                # If too many candidates (shared CWD like ~), skip — can't disambiguate
            fi
        fi

        if [ -n "$session_id" ]; then
            local timestamp
            timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            local cur_status
            cur_status=$(get_status "$target")
            jq -n \
                --arg pane "$target" \
                --arg session_id "$session_id" \
                --arg cwd "$pane_path" \
                --argjson pid "${cc_pid:-0}" \
                --arg status "$cur_status" \
                --arg event "register-all" \
                --arg registered_at "$timestamp" \
                '{pane: $pane, session_id: $session_id, cwd: $cwd, pid: $pid,
                  status: $status, event: $event, registered_at: $registered_at}' \
                > "$AGENTS_DIR/${safe_name}.json"
            echo "  $target — registered (session: ${session_id:0:8}...)"
            count=$((count + 1))
        else
            echo "  $target — could not determine session ID"
        fi
    done < <($TMUX_BIN list-panes -a -F "#{session_name}	#{window_name}	#{pane_index}	#{pane_current_command}	#{pane_title}	#{pane_current_path}" 2>/dev/null)

    echo ""
    echo "Registered $count sessions."
    )  # End subshell — set -e automatically restored
}

cmd_launch() {
    local session=""
    local cc_cmd="cc"
    local timeout=180
    local count=1
    local start_window=""
    local agent_name=""
    local model=""
    local extra_args=()

    # Parse args
    while [ $# -gt 0 ]; do
        case "$1" in
            --session|-s)   session="$2";       shift 2 ;;
            --cmd|-c)       cc_cmd="$2";        shift 2 ;;
            --timeout|-t)   timeout="$2"; require_int "--timeout" "$timeout"; shift 2 ;;
            --count)        count="$2"; require_int "--count" "$count"; shift 2 ;;
            --window|-w)    start_window="$2";  shift 2 ;;
            --name|-n)      agent_name="$2";    shift 2 ;;
            --model|-m)     model="$2";         shift 2 ;;
            --)             shift; extra_args+=("$@"); break ;;
            *)
                # Positional: session name
                if [ -z "$session" ]; then
                    session="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$session" ]; then
        echo "Error: session name required" >&2
        echo "Usage: swarm launch <session> [--count N] [--name NAME] [--model MODEL] [--cmd cc|cc2] [--window W] [--timeout S] [-- extra-claude-args...]" >&2
        exit 1
    fi

    # Verify tmux session exists
    if ! $TMUX_BIN has-session -t "$session" 2>/dev/null; then
        echo "Error: tmux session '$session' not found" >&2
        exit 1
    fi

    local launched=0
    local i=0
    while [ $i -lt "$count" ]; do
        i=$((i + 1))

        # Build the cc command with extra args
        local full_cmd="$cc_cmd"
        # Determine name for this instance (auto-suffix for count > 1)
        local instance_name=""
        if [ -n "$agent_name" ]; then
            if [ "$count" -gt 1 ]; then
                instance_name="${agent_name}-${i}"
            else
                instance_name="$agent_name"
            fi
            full_cmd="$full_cmd -n \"$instance_name\""
        fi
        if [ -n "$model" ]; then
            full_cmd="$full_cmd --model $model"
        fi
        if [ ${#extra_args[@]} -gt 0 ]; then
            for arg in "${extra_args[@]}"; do
                full_cmd="$full_cmd \"$arg\""
            done
        fi

        # Create new tmux window (-d = don't steal focus)
        local target
        if [ -n "$start_window" ] && [ $i -eq 1 ]; then
            target=$($TMUX_BIN new-window -d -t "${session}:${start_window}" -P -F '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null) \
                || target="${session}:${start_window}.0"
        else
            target=$($TMUX_BIN new-window -d -t "${session}" -P -F '#{session_name}:#{window_name}.#{pane_index}')
        fi

        # Rename tmux window if name provided
        if [ -n "$instance_name" ]; then
            local win_target="${target%.*}"
            $TMUX_BIN rename-window -t "$win_target" "$instance_name" 2>/dev/null || true
        fi

        echo "[$i/$count] Launching in $target${instance_name:+ (name: $instance_name)}..."

        # Send the cc command to the new shell
        $TMUX_BIN send-keys -t "$target" "$full_cmd" Enter

        # Wait for CC to be fully ready before launching next
        if wait_cc_ready "$target" "$timeout"; then
            echo ""
            echo "  CC ready in $target"
            launched=$((launched + 1))

            # Ensure CC session name is set via /rename (cc -n may not pass through)
            if [ -n "$instance_name" ]; then
                sleep 1
                $TMUX_BIN send-keys -t "$target" "/rename $instance_name" Enter
                sleep 0.5
            fi
        else
            echo ""
            echo "  WARNING: CC did not become ready in $target within ${timeout}s" >&2
            echo "  Continuing to next launch..." >&2
        fi
    done

    echo ""
    echo "Launched $launched/$count CC sessions in tmux session '$session'"
}

cmd_send() {
    local target="$1"
    shift
    local message="$*"

    if [ -z "$message" ]; then
        echo "Error: No message provided" >&2
        echo "Usage: swarm send <target> <message>" >&2
        exit 1
    fi

    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')
    local inbox_file="$MAILBOX_DIR/${safe_target}.jsonl"

    # Get sender identity
    local sender="unknown"
    if [ -n "${TMUX:-}" ]; then
        sender=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "unknown")
    fi

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Append message to target's inbox
    printf '%s\n' "$(jq -nc --arg from "$sender" --arg to "$target" --arg msg "$message" --arg ts "$timestamp" \
        '{from: $from, to: $to, message: $msg, timestamp: $ts}')" >> "$inbox_file"

    # Push notification via tmux (queued if target is busy)
    if $TMUX_BIN has-session -t "${target%%:*}" 2>/dev/null; then
        local notify_msg="[swarm:$sender] $message"
        local buf_name="swarm_notify_$$_$(date +%s)_$RANDOM"
        echo "$notify_msg" | $TMUX_BIN load-buffer -b "$buf_name" - 2>/dev/null
        $TMUX_BIN paste-buffer -b "$buf_name" -t "$target" -d 2>/dev/null
        sleep 0.3
        $TMUX_BIN send-keys -t "$target" Enter 2>/dev/null
    fi

    log_activity "send" "target=$target" "from=$sender"
    echo "Message sent to $target (from $sender)"
}

cmd_inbox() {
    # Determine current agent's pane target
    local my_pane="unknown"
    if [ -n "${TMUX:-}" ]; then
        my_pane=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "unknown")
    fi

    # Check for --target override (for reading another agent's inbox)
    local target_pane="$my_pane"
    local clear=true
    while [ $# -gt 0 ]; do
        case "$1" in
            --target)
                target_pane="$2"
                shift 2
                ;;
            --peek)
                clear=false
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local safe_name
    safe_name=$(echo "$target_pane" | tr ':.' '_')
    local inbox_file="$MAILBOX_DIR/${safe_name}.jsonl"

    if [ ! -f "$inbox_file" ] || [ ! -s "$inbox_file" ]; then
        echo "No messages for $target_pane"
        return 0
    fi

    local count
    count=$(wc -l < "$inbox_file" | tr -d ' ')
    echo "=== Inbox for $target_pane ($count messages) ==="
    echo ""

    # Display messages
    while IFS= read -r line; do
        local from ts msg
        from=$(echo "$line" | jq -r '.from // "?"')
        ts=$(echo "$line" | jq -r '.timestamp // "?"')
        msg=$(echo "$line" | jq -r '.message // ""')
        printf "[%s] from %s:\n  %s\n\n" "$ts" "$from" "$msg"
    done < "$inbox_file"

    # Clear inbox unless --peek
    if [ "$clear" = "true" ]; then
        > "$inbox_file"
        echo "(inbox cleared)"
    fi
}

# --- QA protocol ---

cmd_ask() {
    local target="$1"
    shift
    local question="$*"

    if [ -z "$target" ] || [ -z "$question" ]; then
        echo "Usage: swarm ask <target> \"question\"" >&2
        exit 1
    fi

    mkdir -p "$QA_DIR"

    # Get sender identity
    local sender="unknown"
    if [ -n "${TMUX:-}" ]; then
        sender=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "unknown")
    fi

    # Generate QA ID: qa_{timestamp}_{short_hash}
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local short_ts
    short_ts=$(date -u +"%Y%m%d_%H%M%S")
    local hash
    hash=$(echo "${sender}_${target}_${short_ts}_${question}" | shasum | cut -c1-6)
    local qa_id="qa_${short_ts}_${hash}"

    # Create QA record
    local qa_file="$QA_DIR/${qa_id}.json"
    jq -n \
        --arg id "$qa_id" \
        --arg from "$sender" \
        --arg to "$target" \
        --arg question "$question" \
        --arg asked_at "$timestamp" \
        --arg status "pending" \
        '{qa_id: $id, from: $from, to: $to, question: $question,
          asked_at: $asked_at, status: $status, answer: null, answered_at: null}' \
        > "$qa_file"

    # Notify target via inbox
    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')
    local inbox_file="$MAILBOX_DIR/${safe_target}.jsonl"
    mkdir -p "$MAILBOX_DIR"

    printf '%s\n' "$(jq -nc --arg from "$sender" --arg to "$target" \
        --arg msg "[QA] $question (reply with: swarm reply $qa_id \"answer\")" \
        --arg ts "$timestamp" --arg qa_id "$qa_id" --arg type "qa" \
        '{from: $from, to: $to, message: $msg, timestamp: $ts, type: $type, qa_id: $qa_id}')" \
        >> "$inbox_file"

    log_activity "ask" "target=$target" "qa_id=$qa_id"
    echo "QA sent to $target: $qa_id"
    echo "Question: $question"
    echo "Target replies with: swarm reply $qa_id \"answer\""
}

cmd_reply() {
    local qa_id="$1"
    shift
    local answer="$*"

    if [ -z "$qa_id" ] || [ -z "$answer" ]; then
        echo "Usage: swarm reply <qa_id> \"answer\"" >&2
        exit 1
    fi

    local qa_file="$QA_DIR/${qa_id}.json"
    if [ ! -f "$qa_file" ]; then
        echo "Error: QA $qa_id not found" >&2
        exit 1
    fi

    # Check not already answered
    local current_status
    current_status=$(jq -r '.status' "$qa_file")
    if [ "$current_status" = "answered" ]; then
        echo "Warning: QA $qa_id already answered" >&2
    fi

    # Get sender identity
    local sender="unknown"
    if [ -n "${TMUX:-}" ]; then
        sender=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "unknown")
    fi

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Update QA record
    jq --arg answer "$answer" --arg ts "$timestamp" --arg by "$sender" \
        '.answer = $answer | .answered_at = $ts | .answered_by = $by | .status = "answered"' \
        "$qa_file" > "$qa_file.tmp" && mv "$qa_file.tmp" "$qa_file"

    # Notify the asker via inbox
    local asker
    asker=$(jq -r '.from' "$qa_file")
    local question
    question=$(jq -r '.question' "$qa_file")

    local safe_asker
    safe_asker=$(echo "$asker" | tr ':.' '_')
    local inbox_file="$MAILBOX_DIR/${safe_asker}.jsonl"
    mkdir -p "$MAILBOX_DIR"

    printf '%s\n' "$(jq -nc --arg from "$sender" --arg to "$asker" \
        --arg msg "[QA-REPLY] Re: $question -> $answer" \
        --arg ts "$timestamp" --arg qa_id "$qa_id" --arg type "qa_reply" \
        '{from: $from, to: $to, message: $msg, timestamp: $ts, type: $type, qa_id: $qa_id}')" \
        >> "$inbox_file"

    log_activity "reply" "qa_id=$qa_id" "to=$asker"
    echo "Reply sent for $qa_id -> $asker"
}

cmd_qa_list() {
    mkdir -p "$QA_DIR"

    local state_filter=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --state) state_filter="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local count=0
    for qa_file in "$QA_DIR"/qa_*.json; do
        [ -f "$qa_file" ] || continue

        local qa_id status from to question
        qa_id=$(jq -r '.qa_id' "$qa_file")
        status=$(jq -r '.status' "$qa_file")
        from=$(jq -r '.from' "$qa_file")
        to=$(jq -r '.to' "$qa_file")
        question=$(jq -r '.question' "$qa_file")

        if [ -n "$state_filter" ] && [ "$status" != "$state_filter" ]; then
            continue
        fi

        printf "%-30s %-10s %s -> %s\n  Q: %s\n" "$qa_id" "[$status]" "$from" "$to" "$question"

        if [ "$status" = "answered" ]; then
            local answer
            answer=$(jq -r '.answer' "$qa_file")
            printf "  A: %s\n" "$answer"
        fi
        echo ""
        count=$((count + 1))
    done

    if [ "$count" -eq 0 ]; then
        echo "No QA records found${state_filter:+ (state=$state_filter)}"
    fi
}

# --- Task lifecycle ---

cmd_task() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_task_create "$@" ;;
        status) cmd_task_status "$@" ;;
        list)   cmd_task_list "$@" ;;
        *)
            echo "Usage: swarm task <create|status|list> [args]" >&2
            exit 1
            ;;
    esac
}

cmd_task_create() {
    local task_id="" from="" to="" type="task" priority="normal" timeout=1800
    local result_path="" phase="default" prompt_text=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --id)           task_id="$2"; shift 2 ;;
            --from)         from="$2"; shift 2 ;;
            --to)           to="$2"; shift 2 ;;
            --type)         type="$2"; shift 2 ;;
            --priority)     priority="$2"; shift 2 ;;
            --timeout)      timeout="$2"; shift 2 ;;
            --result-path)  result_path="$2"; shift 2 ;;
            --phase)        phase="$2"; shift 2 ;;
            --prompt)       prompt_text="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    # Validate required fields
    if [ -z "$task_id" ]; then
        echo "Error: --id is required" >&2
        exit 1
    fi
    if [[ "$task_id" =~ [/\\] ]]; then
        echo "Error: task_id must not contain path separators" >&2
        exit 1
    fi
    if [ -z "$from" ]; then
        echo "Error: --from is required" >&2
        exit 1
    fi
    if [ -z "$to" ]; then
        echo "Error: --to is required" >&2
        exit 1
    fi

    # Check for duplicates
    local task_dir="$TASKS_DIR/$task_id"
    if [ -d "$task_dir" ]; then
        echo "Error: task '$task_id' already exists" >&2
        exit 1
    fi

    mkdir -p "$task_dir"

    # Default result_path
    if [ -z "$result_path" ]; then
        result_path="$TASKS_DIR/$task_id/result.md"
    fi

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Write envelope.json
    jq -n \
        --arg task_id "$task_id" \
        --arg from "$from" \
        --arg to "$to" \
        --arg type "$type" \
        --arg sent_at "$timestamp" \
        --arg result_path "$result_path" \
        --arg priority "$priority" \
        --argjson timeout "$timeout" \
        --arg phase "$phase" \
        '{
            version: 2,
            task_id: $task_id,
            from: $from,
            to: $to,
            type: $type,
            sent_at: $sent_at,
            result_path: $result_path,
            priority: $priority,
            timeout: $timeout,
            phase: $phase
        }' > "$task_dir/envelope.json"

    # Write status.json
    jq -n \
        --arg task_id "$task_id" \
        --arg state "created" \
        --arg created_at "$timestamp" \
        '{
            task_id: $task_id,
            state: $state,
            created_at: $created_at,
            transitions: [{from: "init", to: "created", at: $created_at}]
        }' > "$task_dir/status.json"

    # Write prompt.md if provided
    if [ -n "$prompt_text" ]; then
        echo "$prompt_text" > "$task_dir/prompt.md"
    fi

    log_activity "task_create" "task_id=$task_id" "from=$from" "to=$to"
    echo "Task created: $task_id"
    echo "  Dir: $task_dir"
}

cmd_task_status() {
    local task_id="${1:-}"
    if [ -z "$task_id" ]; then
        echo "Usage: swarm task status <task_id>" >&2
        exit 1
    fi

    local task_dir="$TASKS_DIR/$task_id"
    if [ ! -d "$task_dir" ]; then
        echo "Error: task '$task_id' not found" >&2
        exit 1
    fi

    local state from to type
    state=$(jq -r '.state' "$task_dir/status.json")
    from=$(jq -r '.from' "$task_dir/envelope.json")
    to=$(jq -r '.to' "$task_dir/envelope.json")
    type=$(jq -r '.type' "$task_dir/envelope.json")

    printf "Task:   %s\n" "$task_id"
    printf "State:  %s\n" "$state"
    printf "Type:   %s\n" "$type"
    printf "From:   %s\n" "$from"
    printf "To:     %s\n" "$to"

    # Show result_path and whether result exists
    local result_path
    result_path=$(jq -r '.result_path' "$task_dir/envelope.json")
    local rp_expanded
    rp_expanded=$(echo "$result_path" | sed "s|^~|$HOME|")
    if [ -f "$rp_expanded" ]; then
        printf "Result: %s (exists)\n" "$result_path"
    else
        printf "Result: %s (pending)\n" "$result_path"
    fi
}

cmd_task_list() {
    local filter_state=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --state) filter_state="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ ! -d "$TASKS_DIR" ] || [ -z "$(ls -A "$TASKS_DIR" 2>/dev/null)" ]; then
        echo "No tasks found"
        return 0
    fi

    printf "%-35s %-12s %-8s %-18s %-18s\n" "TASK_ID" "STATE" "TYPE" "FROM" "TO"
    printf "%-35s %-12s %-8s %-18s %-18s\n" "-------" "-----" "----" "----" "--"

    for task_dir in "$TASKS_DIR"/*/; do
        [ -d "$task_dir" ] || continue
        [ -f "$task_dir/status.json" ] || continue
        [ -f "$task_dir/envelope.json" ] || continue

        local task_id state type from to
        task_id=$(basename "$task_dir")
        state=$(jq -r '.state' "$task_dir/status.json")
        type=$(jq -r '.type' "$task_dir/envelope.json")
        from=$(jq -r '.from' "$task_dir/envelope.json")
        to=$(jq -r '.to' "$task_dir/envelope.json")

        if [ -n "$filter_state" ] && [ "$state" != "$filter_state" ]; then
            continue
        fi

        printf "%-35s %-12s %-8s %-18s %-18s\n" "$task_id" "$state" "$type" "$from" "$to"
    done
}

# --- Agent card ---

cmd_card() {
    local subcmd="${1:-}"

    case "$subcmd" in
        set-role) shift; cmd_card_set "$@" "role" ;;
        set-team) shift; cmd_card_set "$@" "team" ;;
        set-caps) shift; cmd_card_set_caps "$@" ;;
        *)
            # Show card for target
            local target="${subcmd:-}"
            if [ -z "$target" ]; then
                # Auto-detect from tmux
                if [ -n "${TMUX:-}" ]; then
                    target=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "")
                fi
                if [ -z "$target" ]; then
                    echo "Usage: swarm card <target> | swarm card set-role|set-team|set-caps <target> <value>" >&2
                    exit 1
                fi
            fi
            local safe_name
            safe_name=$(echo "$target" | tr ':.' '_')
            local card_file="$AGENTS_DIR/${safe_name}.json"
            if [ ! -f "$card_file" ]; then
                echo "Error: no agent card for $target" >&2
                exit 1
            fi
            jq . "$card_file"
            ;;
    esac
}

cmd_card_set() {
    local target="$1"
    local value="$2"
    local field="$3"

    if [ -z "$target" ] || [ -z "$value" ]; then
        echo "Usage: swarm card set-$field <target> <value>" >&2
        exit 1
    fi

    local safe_name
    safe_name=$(echo "$target" | tr ':.' '_')
    local card_file="$AGENTS_DIR/${safe_name}.json"

    if [ ! -f "$card_file" ]; then
        echo "Error: no agent card for $target" >&2
        exit 1
    fi

    jq --arg v "$value" --arg f "$field" '.[$f] = $v' "$card_file" > "$card_file.tmp" \
        && mv "$card_file.tmp" "$card_file"
    echo "Set $field=$value for $target"
}

cmd_card_set_caps() {
    local target="$1"
    local caps_csv="$2"

    if [ -z "$target" ] || [ -z "$caps_csv" ]; then
        echo "Usage: swarm card set-caps <target> <cap1,cap2,...>" >&2
        exit 1
    fi

    local safe_name
    safe_name=$(echo "$target" | tr ':.' '_')
    local card_file="$AGENTS_DIR/${safe_name}.json"

    if [ ! -f "$card_file" ]; then
        echo "Error: no agent card for $target" >&2
        exit 1
    fi

    # Convert CSV to JSON array
    local caps_json
    caps_json=$(echo "$caps_csv" | tr ',' '\n' | jq -R . | jq -s .)

    jq --argjson caps "$caps_json" '.capabilities = $caps' "$card_file" > "$card_file.tmp" \
        && mv "$card_file.tmp" "$card_file"
    echo "Set capabilities for $target"
}

# --- Topology helpers ---

# Ensure topology.json exists with base structure
_init_topology() {
    if [ ! -f "$TOPOLOGY_FILE" ]; then
        cat > "$TOPOLOGY_FILE" <<'EOF'
{
  "teams": {},
  "special_agents": {},
  "spawn_permissions": {}
}
EOF
    fi
}

# --- Team management ---

cmd_team() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_team_create "$@" ;;
        add)    cmd_team_add "$@" ;;
        remove) cmd_team_remove "$@" ;;
        show)   cmd_team_show "$@" ;;
        list)   cmd_team_list "$@" ;;
        delete) cmd_team_delete "$@" ;;
        *)
            echo "Usage: swarm team <create|add|remove|show|list|delete> [args]" >&2
            exit 1
            ;;
    esac
}

cmd_team_create() {
    local name="" lead="" desc=""

    # First positional arg is team name
    if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
        name="$1"
        shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            --lead)  lead="$2"; shift 2 ;;
            --desc)  desc="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [ -z "$name" ]; then
        echo "Error: team name is required" >&2
        echo "Usage: swarm team create <name> --lead <pane> [--desc \"...\"]" >&2
        exit 1
    fi
    if [ -z "$lead" ]; then
        echo "Error: --lead is required" >&2
        echo "Usage: swarm team create <name> --lead <pane> [--desc \"...\"]" >&2
        exit 1
    fi

    _init_topology

    # Check for duplicate team
    if [ "$(jq --arg n "$name" '.teams | has($n)' "$TOPOLOGY_FILE")" = "true" ]; then
        echo "Error: team '$name' already exists" >&2
        exit 1
    fi

    # Add team to topology
    jq --arg n "$name" --arg l "$lead" --arg d "$desc" \
        '.teams[$n] = {lead: $l, members: [], description: $d}' \
        "$TOPOLOGY_FILE" > "$TOPOLOGY_FILE.tmp" \
        && mv "$TOPOLOGY_FILE.tmp" "$TOPOLOGY_FILE"

    echo "Team created: $name (lead: $lead)"
}

cmd_team_add() {
    local name="${1:-}"
    local pane="${2:-}"

    if [ -z "$name" ] || [ -z "$pane" ]; then
        echo "Usage: swarm team add <name> <pane>" >&2
        exit 1
    fi

    _init_topology

    # Check team exists
    if [ "$(jq --arg n "$name" '.teams | has($n)' "$TOPOLOGY_FILE")" != "true" ]; then
        echo "Error: team '$name' not found" >&2
        exit 1
    fi

    # Check duplicate member
    if [ "$(jq --arg n "$name" --arg p "$pane" '.teams[$n].members | index($p) != null' "$TOPOLOGY_FILE")" = "true" ]; then
        echo "Error: '$pane' is already a member of team '$name'" >&2
        exit 1
    fi

    # Add member
    jq --arg n "$name" --arg p "$pane" \
        '.teams[$n].members += [$p]' \
        "$TOPOLOGY_FILE" > "$TOPOLOGY_FILE.tmp" \
        && mv "$TOPOLOGY_FILE.tmp" "$TOPOLOGY_FILE"

    echo "Added $pane to team $name"
}

cmd_team_remove() {
    local name="${1:-}"
    local pane="${2:-}"

    if [ -z "$name" ] || [ -z "$pane" ]; then
        echo "Usage: swarm team remove <name> <pane>" >&2
        exit 1
    fi

    _init_topology

    # Check team exists
    if [ "$(jq --arg n "$name" '.teams | has($n)' "$TOPOLOGY_FILE")" != "true" ]; then
        echo "Error: team '$name' not found" >&2
        exit 1
    fi

    # Check member exists
    if [ "$(jq --arg n "$name" --arg p "$pane" '.teams[$n].members | index($p) != null' "$TOPOLOGY_FILE")" != "true" ]; then
        echo "Error: '$pane' is not a member of team '$name'" >&2
        exit 1
    fi

    # Remove member
    jq --arg n "$name" --arg p "$pane" \
        '.teams[$n].members = [.teams[$n].members[] | select(. != $p)]' \
        "$TOPOLOGY_FILE" > "$TOPOLOGY_FILE.tmp" \
        && mv "$TOPOLOGY_FILE.tmp" "$TOPOLOGY_FILE"

    echo "Removed $pane from team $name"
}

cmd_team_show() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        echo "Usage: swarm team show <name>" >&2
        exit 1
    fi

    _init_topology

    if [ "$(jq --arg n "$name" '.teams | has($n)' "$TOPOLOGY_FILE")" != "true" ]; then
        echo "Error: team '$name' not found" >&2
        exit 1
    fi

    local lead desc members_count
    lead=$(jq -r --arg n "$name" '.teams[$n].lead' "$TOPOLOGY_FILE")
    desc=$(jq -r --arg n "$name" '.teams[$n].description // ""' "$TOPOLOGY_FILE")
    members_count=$(jq -r --arg n "$name" '.teams[$n].members | length' "$TOPOLOGY_FILE")

    printf "Team:        %s\n" "$name"
    printf "Lead:        %s\n" "$lead"
    [ -n "$desc" ] && printf "Description: %s\n" "$desc"
    printf "Members:     %s\n" "$members_count"

    if [ "$members_count" -gt 0 ]; then
        jq -r --arg n "$name" '.teams[$n].members[]' "$TOPOLOGY_FILE" | while read -r m; do
            printf "  - %s\n" "$m"
        done
    fi
}

cmd_team_list() {
    _init_topology

    local team_count
    team_count=$(jq '.teams | keys | length' "$TOPOLOGY_FILE")

    if [ "$team_count" -eq 0 ]; then
        echo "No teams defined"
        return 0
    fi

    printf "%-20s %-20s %-8s %s\n" "TEAM" "LEAD" "MEMBERS" "DESCRIPTION"
    printf "%-20s %-20s %-8s %s\n" "----" "----" "-------" "-----------"

    jq -r '.teams | to_entries[] | [.key, .value.lead, (.value.members | length | tostring), (.value.description // "")] | @tsv' \
        "$TOPOLOGY_FILE" | while IFS=$'\t' read -r name lead count desc; do
        printf "%-20s %-20s %-8s %s\n" "$name" "$lead" "$count" "$desc"
    done
}

cmd_team_delete() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        echo "Usage: swarm team delete <name>" >&2
        exit 1
    fi

    _init_topology

    if [ "$(jq --arg n "$name" '.teams | has($n)' "$TOPOLOGY_FILE")" != "true" ]; then
        echo "Error: team '$name' not found" >&2
        exit 1
    fi

    jq --arg n "$name" 'del(.teams[$n])' \
        "$TOPOLOGY_FILE" > "$TOPOLOGY_FILE.tmp" \
        && mv "$TOPOLOGY_FILE.tmp" "$TOPOLOGY_FILE"

    echo "Team deleted: $name"
}

# --- Topology display ---

cmd_topology() {
    if [ ! -f "$TOPOLOGY_FILE" ]; then
        echo "No topology defined (run 'swarm team create' first)"
        return 0
    fi

    local team_count
    team_count=$(jq '.teams | keys | length' "$TOPOLOGY_FILE")

    if [ "$team_count" -eq 0 ]; then
        echo "No topology defined (no teams)"
        return 0
    fi

    echo "=== Swarm Topology ==="
    echo ""

    # Teams
    jq -r '.teams | to_entries[] | .key' "$TOPOLOGY_FILE" | while read -r team_name; do
        local lead desc members_count
        lead=$(jq -r --arg n "$team_name" '.teams[$n].lead' "$TOPOLOGY_FILE")
        desc=$(jq -r --arg n "$team_name" '.teams[$n].description // ""' "$TOPOLOGY_FILE")
        members_count=$(jq -r --arg n "$team_name" '.teams[$n].members | length' "$TOPOLOGY_FILE")

        printf "[%s] lead=%s" "$team_name" "$lead"
        [ -n "$desc" ] && printf " — %s" "$desc"
        echo ""

        if [ "$members_count" -gt 0 ]; then
            jq -r --arg n "$team_name" '.teams[$n].members[]' "$TOPOLOGY_FILE" | while read -r m; do
                printf "  %s\n" "$m"
            done
        fi
    done

    # Special agents
    local special_count
    special_count=$(jq '.special_agents | keys | length' "$TOPOLOGY_FILE")
    if [ "$special_count" -gt 0 ]; then
        echo ""
        echo "Special agents:"
        jq -r '.special_agents | to_entries[] | "  \(.key): \(.value)"' "$TOPOLOGY_FILE"
    fi

    # Spawn permissions
    local spawn_count
    spawn_count=$(jq '.spawn_permissions | keys | length' "$TOPOLOGY_FILE")
    if [ "$spawn_count" -gt 0 ]; then
        echo ""
        echo "Spawn permissions:"
        jq -r '.spawn_permissions | to_entries[] | "  \(.key): \(.value)"' "$TOPOLOGY_FILE"
    fi
}

# --- Review Exchange Protocol ---

cmd_review() {
    local source_task_id="" reviewer="" artifact_path=""

    # Parse positional + flags
    if [ $# -ge 1 ] && [[ "$1" != --* ]]; then
        source_task_id="$1"
        shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            --reviewer)   reviewer="$2"; shift 2 ;;
            --artifact)   artifact_path="$2"; shift 2 ;;
            *) echo "Error: unknown option: $1" >&2; exit 1 ;;
        esac
    done

    # Validate required args
    if [ -z "$source_task_id" ]; then
        echo "Error: source task_id is required" >&2
        echo "Usage: swarm review <task_id> --reviewer <pane> [--artifact <path>]" >&2
        exit 1
    fi
    if [ -z "$reviewer" ]; then
        echo "Error: --reviewer is required" >&2
        echo "Usage: swarm review <task_id> --reviewer <pane> [--artifact <path>]" >&2
        exit 1
    fi

    # 1. Validate source task exists
    local source_dir="$TASKS_DIR/$source_task_id"
    if [ ! -d "$source_dir" ]; then
        echo "Error: source task '$source_task_id' not found (no directory at $source_dir)" >&2
        exit 1
    fi

    # 2. Determine artifact to review
    if [ -z "$artifact_path" ]; then
        # Default: use result.md from source task, or result_path from envelope
        local env_result_path=""
        if [ -f "$source_dir/envelope.json" ]; then
            env_result_path=$(jq -r '.result_path // empty' "$source_dir/envelope.json")
        fi
        if [ -n "$env_result_path" ] && [ -f "$env_result_path" ]; then
            artifact_path="$env_result_path"
        elif [ -f "$source_dir/result.md" ]; then
            artifact_path="$source_dir/result.md"
        else
            echo "Error: source task has no result.md and no --artifact specified" >&2
            echo "Hint: write a result to $source_dir/result.md or pass --artifact <path>" >&2
            exit 1
        fi
    fi

    # 3. Determine round number (auto-increment)
    local round=1
    while [ -d "$TASKS_DIR/${source_task_id}_review_r${round}" ]; do
        round=$((round + 1))
    done

    local review_task_id="${source_task_id}_review_r${round}"
    local review_dir="$TASKS_DIR/$review_task_id"

    # 4. Read author from source envelope (the 'to' field is who did the work)
    local author=""
    if [ -f "$source_dir/envelope.json" ]; then
        author=$(jq -r '.to // empty' "$source_dir/envelope.json")
    fi
    if [ -z "$author" ]; then
        author="unknown"
    fi

    # 5. Create review task via task create
    "$0" task create \
        --id "$review_task_id" \
        --from "$author" \
        --to "$reviewer" \
        --type "review" \
        --prompt "__placeholder__"

    # 6. Update envelope with result_path pointing to review.md
    local review_result_path="$review_dir/review.md"
    jq --arg rp "$review_result_path" '.result_path = $rp' \
        "$review_dir/envelope.json" > "$review_dir/envelope.json.tmp" \
        && mv "$review_dir/envelope.json.tmp" "$review_dir/envelope.json"

    # 7. Generate proper prompt.md with review instructions
    cat > "$review_dir/prompt.md" <<REVIEW_PROMPT
# Review Request: ${source_task_id} (Round ${round})

## Artifact to Review

\`${artifact_path}\`

Read the artifact above and write your review to: \`${review_result_path}\`

## Review Format

Structure your review with these sections:

### Verdict
ACCEPT / REVISE / REJECT — one word, then a one-sentence justification.

### Critical Issues
Blocking problems that must be fixed. If none, write "None."

### Important Issues
Significant concerns that should be addressed. If none, write "None."

### Minor Issues
Small improvements, style nits, typos. If none, write "None."

### Strengths
What works well — be specific.

### Summary
2-3 sentence overall assessment.
REVIEW_PROMPT

    # 8. Dispatch the review task (best-effort: task files are already created)
    if "$0" dispatch --task "$review_task_id" 2>/dev/null; then
        : # dispatch succeeded
    else
        # Tmux may be unavailable or target unreachable -- task is still ready
        # Manually update status to dispatched since dispatch didn't complete
        local timestamp
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        local prev_state
        prev_state=$(jq -r '.state' "$review_dir/status.json")
        if [ "$prev_state" != "dispatched" ]; then
            jq --arg ts "$timestamp" --arg prev "$prev_state" '
                .state = "dispatched" |
                .dispatched_at = $ts |
                .transitions += [{from: $prev, to: "dispatched", at: $ts}]
            ' "$review_dir/status.json" > "$review_dir/status.json.tmp" \
                && mv "$review_dir/status.json.tmp" "$review_dir/status.json"
        fi
    fi

    echo "Review task created: $review_task_id (round $round)"
    echo "  Reviewing: $artifact_path"
    echo "  Reviewer: $reviewer"
    echo "  Result: $review_result_path"
}

# --- Heartbeat ---

cmd_heartbeat() {
    local timeout=60  # default: 60 seconds

    while [ $# -gt 0 ]; do
        case "$1" in
            --timeout) timeout="$2"; require_int "--timeout" "$timeout"; shift 2 ;;
            *) shift ;;
        esac
    done

    local cards=("$AGENTS_DIR"/*.json)
    if [ ! -f "${cards[0]:-}" ]; then
        echo "No agents registered"
        return 0
    fi

    local now
    now=$(date +%s)

    printf "%-25s %-8s %-10s %s\n" "AGENT" "STATUS" "LIVENESS" "LAST HEARTBEAT"
    printf "%-25s %-8s %-10s %s\n" "-----" "------" "--------" "--------------"

    for card in "${cards[@]}"; do
        local pane status hb liveness age_str
        pane=$(jq -r '.pane // "?"' "$card")
        status=$(get_status "$pane" 2>/dev/null || echo "?")
        hb=$(jq -r '.last_heartbeat // empty' "$card")

        if [ -z "$hb" ]; then
            liveness="no heartbeat"
            age_str="-"
        else
            # Parse ISO timestamp to epoch
            local hb_epoch
            hb_epoch=$(TZ=UTC date -jf "%Y-%m-%dT%H:%M:%SZ" "$hb" +%s 2>/dev/null || \
                       date -u -d "$hb" +%s 2>/dev/null || echo 0)
            local age=$((now - hb_epoch))

            if [ "$age" -le "$timeout" ]; then
                liveness="alive"
            else
                liveness="stale"
            fi

            if [ "$age" -lt 60 ]; then
                age_str="${age}s ago"
            elif [ "$age" -lt 3600 ]; then
                age_str="$((age / 60))m ago"
            else
                age_str="$((age / 3600))h ago"
            fi
        fi

        printf "%-25s %-8s %-10s %s\n" "$pane" "$status" "$liveness" "$age_str"
    done
}

# --- Drain signal ---

cmd_drain() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        echo "Usage: swarm drain <target>" >&2
        exit 1
    fi

    mkdir -p "$SWARM_DIR/drain"
    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')

    # Write drain signal file
    echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" > "$SWARM_DIR/drain/$safe_target"

    # Update agent card if it exists
    local card="$AGENTS_DIR/${safe_target}.json"
    if [ -f "$card" ]; then
        jq '. + {draining: true}' "$card" > "$card.tmp" && mv "$card.tmp" "$card"
    fi

    log_activity "drain" "target=$target"
    echo "Drain signal sent to $target (will stop after current task)"
}

cmd_cancel_drain() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        echo "Usage: swarm cancel-drain <target>" >&2
        exit 1
    fi

    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')

    rm -f "$SWARM_DIR/drain/$safe_target"

    # Update agent card if it exists
    local card="$AGENTS_DIR/${safe_target}.json"
    if [ -f "$card" ]; then
        jq '. + {draining: false}' "$card" > "$card.tmp" && mv "$card.tmp" "$card"
    fi

    echo "Drain cancelled for $target"
}

cmd_check_drain() {
    local target=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --target) target="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ -z "$target" ]; then
        echo "Usage: swarm check-drain --target <pane>" >&2
        exit 1
    fi

    local safe_target
    safe_target=$(echo "$target" | tr ':.' '_')

    if [ -f "$SWARM_DIR/drain/$safe_target" ]; then
        echo "Status: draining"
    else
        echo "Status: active"
    fi
}

# --- Activity log ---

cmd_log() {
    local last=50

    while [ $# -gt 0 ]; do
        case "$1" in
            --last) last="$2"; require_int "--last" "$last"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ ! -f "$ACTIVITY_LOG" ] || [ ! -s "$ACTIVITY_LOG" ]; then
        echo "No activity logged yet"
        return 0
    fi

    tail -n "$last" "$ACTIVITY_LOG" | jq -r \
        '"\(.timestamp)  \(.action)\t\(to_entries | map(select(.key != "action" and .key != "timestamp")) | map("\(.key)=\(.value)") | join(" "))"'
}

# --- Triage: review result -> Linear tickets ---

cmd_triage() {
    local task_id="" dry_run=false min_severity="minor" linear_bin="linear"

    # Parse args
    if [ $# -lt 1 ] || [[ "$1" == --* ]]; then
        echo "Usage: swarm triage <task_id> [--dry-run] [--min-severity critical|important|minor] [--linear-bin path]" >&2
        exit 1
    fi
    task_id="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run)       dry_run=true; shift ;;
            --min-severity)  min_severity="$2"; shift 2 ;;
            --linear-bin)    linear_bin="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    local task_dir="$SWARM_DIR/tasks/$task_id"
    local result_file="$task_dir/result.md"

    if [ ! -f "$result_file" ]; then
        echo "Error: $result_file not found" >&2
        exit 1
    fi

    # Severity level to numeric (for filtering)
    _severity_num() {
        case "$1" in
            critical) echo 1 ;;
            important) echo 2 ;;
            minor) echo 3 ;;
            *) echo 4 ;;
        esac
    }

    local min_sev_num
    min_sev_num=$(_severity_num "$min_severity")

    # Parse structured tables under ### Critical / ### Important / ### Minor headers
    local current_severity="" issue_count=0
    local -a issues=()  # "severity|id|confidence|location|description"

    while IFS= read -r line; do
        # Detect severity header
        if echo "$line" | grep -qiE '^###\s+Critical'; then
            current_severity="critical"
            continue
        elif echo "$line" | grep -qiE '^###\s+Important'; then
            current_severity="important"
            continue
        elif echo "$line" | grep -qiE '^###\s+(Minor|Nice)'; then
            current_severity="minor"
            continue
        elif echo "$line" | grep -qE '^##[^#]'; then
            # New section -- reset severity context
            current_severity=""
            continue
        fi

        # Skip non-table lines and header/separator rows
        if [ -z "$current_severity" ]; then continue; fi
        if ! echo "$line" | grep -q '|'; then continue; fi
        if echo "$line" | grep -qE '^\|\s*[-]+'; then continue; fi
        if echo "$line" | grep -qiE '^\|\s*#\s*\|'; then continue; fi

        # Parse table row: | id | confidence | location | issue |
        local issue_id confidence location description
        issue_id=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2}')
        confidence=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $3); print $3}')
        location=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $4); print $4}')
        description=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $5); print $5}')

        if [ -z "$issue_id" ] || [ -z "$description" ]; then continue; fi

        # Strip markdown bold markers from description for ticket title
        local clean_desc
        clean_desc=$(echo "$description" | sed 's/\*\*//g' | sed 's/ -- .*//')

        issues+=("${current_severity}|${issue_id}|${confidence}|${location}|${clean_desc}|${description}")
        issue_count=$((issue_count + 1))
    done < "$result_file"

    if [ $issue_count -eq 0 ]; then
        echo "Error: No structured issues found in $result_file" >&2
        exit 1
    fi

    echo "Found $issue_count issue(s) in $task_id"
    echo ""

    # Process issues
    local created=0 skipped=0
    local -a ticket_ids=()

    for entry in "${issues[@]}"; do
        IFS='|' read -r severity issue_id confidence location clean_desc full_desc <<< "$entry"

        local sev_num
        sev_num=$(_severity_num "$severity")

        # Filter by min severity
        if [ "$sev_num" -gt "$min_sev_num" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        # Map severity to Linear priority
        local priority
        priority=$sev_num

        local sev_upper
        sev_upper=$(echo "$severity" | tr '[:lower:]' '[:upper:]' | head -c1)$(echo "$severity" | tail -c+2)

        if $dry_run; then
            printf "  [DRY RUN] %-10s %-6s P%d  %s: %s\n" "$sev_upper" "$issue_id" "$priority" "$location" "$clean_desc"
            created=$((created + 1))
        else
            # Create Linear ticket
            local ticket_body="**${issue_id}** (${confidence}) at ${location}\n\n${full_desc}\n\nSource: swarm triage ${task_id}"
            local ticket_id
            ticket_id=$("$linear_bin" i create "$clean_desc" \
                --priority "$priority" \
                2>/dev/null | grep -oE '[A-Z]+-[0-9]+' | head -1)

            if [ -n "$ticket_id" ]; then
                printf "  %-10s %-6s -> %s (P%d)\n" "$sev_upper" "$issue_id" "$ticket_id" "$priority"
                ticket_ids+=("$ticket_id")
                created=$((created + 1))
            else
                echo "  Warning: failed to create ticket for $issue_id" >&2
            fi
        fi
    done

    echo ""
    if $dry_run; then
        echo "DRY RUN: would create $created ticket(s), skipped $skipped"
    else
        echo "Created $created ticket(s): ${ticket_ids[*]}"

        # Log to activity
        local timestamp
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        local ticket_csv
        ticket_csv=$(IFS=','; echo "${ticket_ids[*]}")
        echo "{\"timestamp\":\"$timestamp\",\"action\":\"triage\",\"task_id\":\"$task_id\",\"tickets\":\"$ticket_csv\",\"count\":$created}" \
            >> "$SWARM_DIR/activity.jsonl"
    fi
}

# --- Merge coordinator ---

cmd_merge() {
    local base="" sources="" dry_run=false force=false repo="."

    while [ $# -gt 0 ]; do
        case "$1" in
            --base)     base="$2"; shift 2 ;;
            --sources)  sources="$2"; shift 2 ;;
            --dry-run)  dry_run=true; shift ;;
            --force)    force=true; shift ;;
            --repo)     repo="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    # Validate base branch exists
    if [ -z "$base" ]; then
        echo "Error: --base is required" >&2
        echo "Usage: swarm merge --base <branch> [--sources b1,b2] [--dry-run] [--force]" >&2
        exit 1
    fi

    if ! git -C "$repo" rev-parse --verify "$base" >/dev/null 2>&1; then
        echo "Error: base branch '$base' not found" >&2
        exit 1
    fi

    # Enumerate source branches
    local -a branch_list=()
    if [ -n "$sources" ]; then
        IFS=',' read -ra branch_list <<< "$sources"
    else
        # Auto-detect: worktree branches except base
        while IFS= read -r line; do
            local wt_branch
            wt_branch=$(echo "$line" | awk '{print $3}' | sed 's/\[//;s/\]//')
            if [ -n "$wt_branch" ] && [ "$wt_branch" != "$base" ]; then
                branch_list+=("$wt_branch")
            fi
        done < <(git -C "$repo" worktree list 2>/dev/null | tail -n +2)
    fi

    if [ ${#branch_list[@]} -eq 0 ]; then
        echo "Error: No source branches found" >&2
        exit 1
    fi

    echo "Analyzing ${#branch_list[@]} branch(es) against $base..."
    echo ""

    local clean_count=0 conflict_count=0
    local -a clean_branches=()
    local -a conflict_branches=()

    for branch in "${branch_list[@]}"; do
        if ! git -C "$repo" rev-parse --verify "$branch" >/dev/null 2>&1; then
            echo "  [SKIP]     $branch (branch not found)"
            continue
        fi

        # Get diff stats
        local stat_summary
        stat_summary=$(git -C "$repo" diff --shortstat "$base...$branch" 2>/dev/null | \
            sed 's/^ *//' | sed 's/ file.*/file/' | sed 's/ insertion.*/+/' | \
            tr -d '\n')
        local file_count
        file_count=$(git -C "$repo" diff --name-only "$base...$branch" 2>/dev/null | wc -l | tr -d ' ')

        # Run merge-tree for conflict detection (|| true prevents set -e abort)
        local merge_output merge_exit=0
        merge_output=$(git -C "$repo" merge-tree --write-tree "$base" "$branch" 2>&1) || merge_exit=$?

        if [ $merge_exit -eq 0 ]; then
            printf "  [CLEAN]    %-20s (%s files changed)\n" "$branch" "$file_count"
            clean_count=$((clean_count + 1))
            clean_branches+=("$branch")
        else
            conflict_count=$((conflict_count + 1))
            conflict_branches+=("$branch")
            # Extract conflicted file names
            local conflicts
            conflicts=$(echo "$merge_output" | grep "^CONFLICT" | sed 's/.*Merge conflict in /  - /' | sed 's/CONFLICT (\([^)]*\)): .*/  - \1 conflict/')
            if [ -z "$conflicts" ]; then
                conflicts=$(echo "$merge_output" | grep -v "^[0-9a-f]" | head -5)
            fi
            local conflict_file_count
            conflict_file_count=$(echo "$merge_output" | grep -c "CONFLICT" || true)
            printf "  [CONFLICT] %-20s %s conflicted file(s):\n" "$branch" "$conflict_file_count"
            echo "$merge_output" | grep "CONFLICT" | while read -r cline; do
                local cfile
                cfile=$(echo "$cline" | sed 's/.*Merge conflict in //' | sed 's/CONFLICT.*//')
                if [ -n "$cfile" ]; then
                    echo "               - $cfile"
                else
                    echo "               $cline"
                fi
            done
        fi
    done

    echo ""
    echo "Result: $clean_count clean, $conflict_count conflict(s)"

    if $dry_run; then
        if [ $conflict_count -gt 0 ] && [ $clean_count -gt 0 ]; then
            local clean_csv
            clean_csv=$(IFS=','; echo "${clean_branches[*]}")
            echo "Run 'swarm merge --base $base --sources $clean_csv' to merge clean branches."
        fi
        [ $conflict_count -gt 0 ] && exit 1
        exit 0
    fi

    # Abort if conflicts and no --force
    if [ $conflict_count -gt 0 ] && ! $force; then
        echo "Aborting: resolve conflicts first or use --force"
        exit 1
    fi

    # Sequential merge
    if [ ${#clean_branches[@]} -eq 0 ]; then
        echo "No clean branches to merge."
        exit 0
    fi

    local original_branch
    original_branch=$(git -C "$repo" branch --show-current)

    if ! git -C "$repo" diff-index --quiet HEAD -- 2>/dev/null; then
        echo "Error: working tree is dirty. Commit or stash changes first." >&2
        exit 1
    fi

    git -C "$repo" checkout "$base" 2>/dev/null

    for branch in "${clean_branches[@]}"; do
        echo "Merging $branch into $base..."
        if ! git -C "$repo" merge --no-ff "$branch" -m "merge: $branch into $base" 2>&1; then
            echo "Error: merge of $branch failed. Aborting." >&2
            git -C "$repo" merge --abort 2>/dev/null || true
            git -C "$repo" checkout "$original_branch" 2>/dev/null || true
            exit 1
        fi
        echo "  Merged $branch"
    done

    echo ""
    echo "Merged ${#clean_branches[@]} branch(es) into $base."

    # Return to original branch if different
    if [ "$original_branch" != "$base" ] && [ -n "$original_branch" ]; then
        git -C "$repo" checkout "$original_branch" 2>/dev/null || true
    fi
}

# --- Monitor agent ---

MONITOR_DIR="$SWARM_DIR/monitor"

cmd_monitor_start() {
    local session=""
    local dry_run=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --session|-s) session="$2"; shift 2 ;;
            --dry-run)    dry_run=true; shift ;;
            *)
                if [ -z "$session" ]; then
                    session="$1"
                fi
                shift
                ;;
        esac
    done

    # Create monitor directory and initial status
    mkdir -p "$MONITOR_DIR"
    echo "[swarm monitor: starting] $(date '+%Y-%m-%d %H:%M')" > "$MONITOR_DIR/status.txt"

    if [ "$dry_run" = "true" ]; then
        echo "Dry run: monitor directory created at $MONITOR_DIR"
        echo "Dry run: status.txt initialized"
        echo "Dry run: would launch CC session and dispatch monitor.md prompt"
        return 0
    fi

    # Detect session from topology special_agents.monitor or use provided/default
    if [ -z "$session" ]; then
        if [ -f "$TOPOLOGY_FILE" ]; then
            local topo_monitor
            topo_monitor=$(jq -r '.special_agents.monitor // empty' "$TOPOLOGY_FILE" 2>/dev/null)
            if [ -n "$topo_monitor" ]; then
                session="${topo_monitor%%:*}"
            fi
        fi
    fi

    if [ -z "$session" ]; then
        if [ -n "${TMUX:-}" ]; then
            session=$($TMUX_BIN display-message -p -t "${TMUX_PANE:-}" '#{session_name}' 2>/dev/null || echo "")
        fi
    fi

    if [ -z "$session" ]; then
        echo "Error: no session specified and cannot auto-detect" >&2
        echo "Usage: swarm monitor-start [<session>] [--dry-run]" >&2
        exit 1
    fi

    # Verify tmux session exists
    if ! $TMUX_BIN has-session -t "$session" 2>/dev/null; then
        echo "Error: tmux session '$session' not found" >&2
        exit 1
    fi

    # Resolve the monitor.md template path
    local script_src="$0"
    while [ -L "$script_src" ]; do script_src="$(readlink "$script_src")"; done
    local script_dir
    script_dir="$(cd "$(dirname "$script_src")" && pwd -P)"
    local template_path="${script_dir}/../agents/monitor.md"
    if [ ! -f "$template_path" ]; then
        echo "Error: monitor template not found at $template_path" >&2
        exit 1
    fi

    # Launch a CC session named "monitor"
    echo "Launching monitor agent in session '$session'..."
    cmd_launch "$session" --name monitor --count 1

    # Find the monitor pane
    local monitor_target=""
    monitor_target=$($TMUX_BIN list-panes -t "${session}" -a -F '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null \
        | grep ':monitor\.' | head -1)

    if [ -z "$monitor_target" ]; then
        monitor_target=$($TMUX_BIN list-panes -t "${session}" -a -F '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null \
            | tail -1)
    fi

    if [ -z "$monitor_target" ]; then
        echo "Error: failed to locate the monitor pane" >&2
        exit 1
    fi

    # Register monitor in topology
    if [ -f "$TOPOLOGY_FILE" ]; then
        jq --arg t "$monitor_target" '.special_agents.monitor = $t' \
            "$TOPOLOGY_FILE" > "$TOPOLOGY_FILE.tmp" \
            && mv "$TOPOLOGY_FILE.tmp" "$TOPOLOGY_FILE"
    fi

    # Update status
    echo "[swarm monitor: launched] $(date '+%Y-%m-%d %H:%M') pane=$monitor_target" > "$MONITOR_DIR/status.txt"

    # Dispatch the monitor prompt
    local abs_template
    abs_template=$(cd "$(dirname "$template_path")" && echo "$(pwd -P)/$(basename "$template_path")")
    cmd_dispatch "$monitor_target" --file "$abs_template"

    echo "Monitor agent started: $monitor_target"
    echo "Template: $abs_template"
    echo "Status: $MONITOR_DIR/status.txt"
}

cmd_monitor_status() {
    local status_file="$MONITOR_DIR/status.txt"

    if [ ! -f "$status_file" ]; then
        echo "Error: No monitor status found — monitor is not running" >&2
        echo "Start the monitor with: swarm monitor-start [session]" >&2
        exit 1
    fi

    if [ ! -s "$status_file" ]; then
        echo "Error: Monitor status file is empty — monitor may not be running" >&2
        exit 1
    fi

    echo "=== Swarm Monitor Status ==="
    echo ""
    cat "$status_file"

    # Show monitor pane target if available in topology
    if [ -f "$TOPOLOGY_FILE" ]; then
        local monitor_pane
        monitor_pane=$(jq -r '.special_agents.monitor // empty' "$TOPOLOGY_FILE" 2>/dev/null)
        if [ -n "$monitor_pane" ]; then
            echo ""
            echo "Monitor pane: $monitor_pane"
        fi
    fi
}

# --- Rename: atomic 3-layer name update ---

cmd_rename() {
    local name="" target="" old_pane="" card_only=false

    # Parse args
    while [ $# -gt 0 ]; do
        case "$1" in
            --target|-t) target="$2"; shift 2 ;;
            --old-pane)  old_pane="$2"; shift 2 ;;
            --card-only) card_only=true; shift ;;
            --*)         echo "Unknown option: $1" >&2; exit 1 ;;
            *)           name="$1"; shift ;;
        esac
    done

    if [ -z "$name" ]; then
        echo "Usage: swarm rename <name> [--target <pane>]" >&2
        echo "  Atomically updates CC session name, pane title, and tmux window name." >&2
        echo "  <name> can include prefix: '[dev] my-feature' -> window_name='my-feature'" >&2
        exit 1
    fi

    # Extract window_name by stripping [prefix] if present
    local window_name="$name"
    if [[ "$name" =~ ^\[.*\]\ (.+)$ ]]; then
        window_name="${BASH_REMATCH[1]}"
    fi

    # Determine pane target and session info
    local pane_target="" session_name="" pane_index=""

    if ! $card_only; then
        if [ -z "${TMUX:-}" ]; then
            echo "Error: not inside tmux — cannot rename" >&2
            exit 1
        fi

        if [ -z "$target" ]; then
            # Rename self
            target="$TMUX_PANE"
        fi

        # Read current identity before rename
        if [ -z "$old_pane" ]; then
            old_pane=$($TMUX_BIN display-message -t "$target" -p \
                '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null || echo "")
        fi

        session_name=$($TMUX_BIN display-message -t "$target" -p '#{session_name}' 2>/dev/null)
        pane_index=$($TMUX_BIN display-message -t "$target" -p '#{pane_index}' 2>/dev/null)

        # Layer 1: CC session name + pane title (via /rename)
        $TMUX_BIN send-keys -t "$target" "/rename $name" Enter

        # Layer 2: tmux window name (immediate, no hook wait)
        $TMUX_BIN rename-window -t "$target" "$window_name"

        pane_target="${session_name}:${window_name}.${pane_index}"
    else
        # Card-only mode (testing): derive pane_target from old_pane + new window_name
        if [ -z "$old_pane" ]; then
            echo "Error: --card-only requires --old-pane" >&2
            exit 1
        fi
        session_name="${old_pane%%:*}"
        pane_index="${old_pane##*.}"
        pane_target="${session_name}:${window_name}.${pane_index}"
    fi

    # Layer 3: update agent card (rename file + update pane field)
    if [ -n "$old_pane" ]; then
        local old_safe new_safe
        old_safe=$(echo "$old_pane" | tr ':.' '_')
        new_safe=$(echo "$pane_target" | tr ':.' '_')
        local old_card="$AGENTS_DIR/${old_safe}.json"
        local new_card="$AGENTS_DIR/${new_safe}.json"

        if [ -f "$old_card" ]; then
            if [ "$old_card" = "$new_card" ]; then
                # Same file — just update pane field
                jq --arg p "$pane_target" '.pane = $p' "$old_card" > "$old_card.tmp" \
                    && mv "$old_card.tmp" "$old_card"
            else
                # Different file — migrate
                jq --arg p "$pane_target" '.pane = $p' "$old_card" > "$new_card"
                rm -f "$old_card"
            fi
        fi
    fi

    echo "Renamed: $pane_target ($name)"
}

# --- Main ---

case "${1:-}" in
    task)
        shift
        cmd_task "$@"
        ;;
    card)
        shift
        cmd_card "$@"
        ;;
    team)
        shift
        cmd_team "$@"
        ;;
    topology)
        shift
        cmd_topology "$@"
        ;;
    review)
        shift
        cmd_review "$@"
        ;;
    list|ls)
        shift
        cmd_list "$@"
        ;;
    dispatch|d)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm dispatch <target> <prompt|--file path|--task task_id>" >&2
            exit 1
        fi
        cmd_dispatch "$@"
        ;;
    monitor|m)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm monitor <target> [--wait|--tail N]" >&2
            exit 1
        fi
        cmd_monitor "$@"
        ;;
    collect|c)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm collect <target>" >&2
            exit 1
        fi
        cmd_collect "$@"
        ;;
    status|s)
        shift
        cmd_status "$@"
        ;;
    send)
        shift
        if [ $# -lt 2 ]; then
            echo "Usage: swarm send <target> <message>" >&2
            exit 1
        fi
        cmd_send "$@"
        ;;
    inbox)
        shift
        cmd_inbox "$@"
        ;;
    ask)
        shift
        if [ $# -lt 2 ]; then
            echo "Usage: swarm ask <target> \"question\"" >&2
            exit 1
        fi
        cmd_ask "$@"
        ;;
    reply)
        shift
        if [ $# -lt 2 ]; then
            echo "Usage: swarm reply <qa_id> \"answer\"" >&2
            exit 1
        fi
        cmd_reply "$@"
        ;;
    qa)
        shift
        cmd_qa_list "$@"
        ;;
    launch|l)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm launch <session> [--count N] [--cmd cc|cc2] [--window W] [--timeout S]" >&2
            exit 1
        fi
        cmd_launch "$@"
        ;;
    triage)
        shift
        cmd_triage "$@"
        ;;
    merge)
        shift
        cmd_merge "$@"
        ;;
    heartbeat|hb)
        shift
        cmd_heartbeat "$@"
        ;;
    drain)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm drain <target>" >&2
            exit 1
        fi
        cmd_drain "$@"
        ;;
    cancel-drain)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm cancel-drain <target>" >&2
            exit 1
        fi
        cmd_cancel_drain "$@"
        ;;
    check-drain)
        shift
        cmd_check_drain "$@"
        ;;
    log)
        shift
        cmd_log "$@"
        ;;
    rename)
        shift
        cmd_rename "$@"
        ;;
    register-all|ra)
        cmd_register_all
        ;;
    monitor-start)
        shift
        cmd_monitor_start "$@"
        ;;
    monitor-status)
        shift
        cmd_monitor_status "$@"
        ;;
    run)
        shift
        if [ $# -lt 1 ]; then
            echo "Usage: swarm run <dag.json> [--resume] [--dry-run] [--poll-interval N] [--timeout N]" >&2
            exit 1
        fi
        # Resolve symlinks (BSD readlink without -f, loop for chains)
        _src="$0"
        while [ -L "$_src" ]; do _src="$(readlink "$_src")"; done
        SCRIPT_DIR="$(cd "$(dirname "$_src")" && pwd -P)"
        uv run --project ~/.claude/cc-python python3 \
            "${SCRIPT_DIR}/swarm_dag.py" "$@"
        ;;
    help|--help|-h)
        cat <<'USAGE'
swarm — Peer-mesh multi-agent coordination over tmux

Commands:
  list                              List all Claude Code sessions
  launch <session> [options]        Launch CC sessions sequentially in tmux
  dispatch <target> <prompt>        Send task to a CC session
  dispatch <target> --file <path>   Send task from file
  dispatch --task <id>              Dispatch pre-created task (target from envelope)
  task create --id X --from --to   Create a structured task with envelope
  task status <id>                 Show task state
  task list [--state S]            List tasks, optionally filtered by state
  review <task_id> --reviewer <p>  Request cross-agent review
  card [<target>]                  Show agent card (auto-detect if no target)
  card set-role <target> <role>    Set agent role
  card set-team <target> <team>    Assign agent to team
  card set-caps <target> <c1,c2>   Set agent capabilities
  monitor <target>                  Capture pane output
  monitor <target> --wait [timeout] Wait until session is idle
  monitor <target> --tail <n>       Last n lines
  collect <target>                  Get last assistant response
  status                            Dashboard of all agents
  send <target> <message>           Send async message to agent's inbox
  inbox [--peek] [--target <pane>]  Read (and clear) inbox messages
  ask <target> "question"           Send QA question (creates tracked QA record)
  reply <qa_id> "answer"            Reply to a QA question
  qa [--state pending|answered]     List QA records
  team create <name> --lead <pane>  Create a team
  team add <name> <pane>            Add member to team
  team remove <name> <pane>         Remove member from team
  team show <name>                  Show team details
  team list                         List all teams
  team delete <name>                Delete a team
  topology                          Pretty-print full topology
  monitor-start [session] [--dry-run]  Launch the monitor watchdog agent
  monitor-status                    Show monitor agent's latest report
  heartbeat [--timeout N]            Show agent liveness (default: 60s)
  drain <target>                     Signal agent to stop after current task
  cancel-drain <target>              Cancel a drain signal
  check-drain --target <pane>        Check if agent is draining
  log [--last N]                      Show activity log (default: last 50)
  triage <task_id> [--dry-run]       Parse review result, create Linear tickets
  merge --base B [--sources S1,S2]  Merge worktree branches (conflict-safe)
  rename <name> [--target <pane>]   Atomic rename (CC + pane title + window name + card)
  register-all                      Force-register all CC sessions
  run <dag.json> [options]          Execute a DAG workflow

Launch options:
  --name NAME, -n NAME              Name the agent (sets CC session name + tmux window name)
  --model MODEL, -m MODEL           Model override (opus, sonnet, haiku)
  --count N                         Number of sessions to launch (default: 1)
  --cmd cc|cc2, -c cc|cc2           CC command to use (default: cc)
  --window W, -w W                  Window index for first launch
  --timeout S, -t S                 Max seconds to wait per session (default: 180)
  -- [args...]                      Extra args passed through to claude CLI

Run options:
  --resume                          Resume from existing state file
  --dry-run                         Validate and print plan without dispatching
  --poll-interval N                 Seconds between polls (default: 10)
  --timeout N                       Max seconds for DAG execution (default: 3600)

Aliases: ls=list, l=launch, d=dispatch, m=monitor, c=collect, s=status

Examples:
  swarm list
  swarm launch xz -n researcher           # Launch named agent
  swarm launch xz -n worker --count 3    # Launch worker-1, worker-2, worker-3
  swarm launch xz -n fast -m sonnet      # Launch with sonnet model
  swarm launch xz --count 2 --cmd cc2    # Launch 2 sessions with cc2
  swarm dispatch cw:3.0 "Fix the heartbeat bug in uclaw"
  swarm dispatch xz:5.0 --file /tmp/long_task.md
  swarm monitor cw:3.0 --wait 300
  swarm collect cw:3.0
  swarm send cw:3.0 "Results ready at /tmp/output.json"
  swarm inbox
  swarm ask mbp:planner.0 "Should the threat model assume black-box?"
  swarm reply qa_20260329_abc123 "Yes, black-box only. See BlueSuffix Section 3."
  swarm qa --state pending            # List unanswered questions
  swarm status
  swarm monitor-start mbp                # Launch monitor in session mbp
  swarm monitor-status                   # Check monitor's latest report
  swarm run workflow.json --dry-run
  swarm run workflow.json --resume --timeout 7200
USAGE
        ;;
    *)
        echo "Unknown command: ${1:-}" >&2
        echo "Run 'swarm help' for usage" >&2
        exit 1
        ;;
esac
